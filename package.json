{
  "name": "hrkmtsmt.me",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "lint": "biome lint",
    "format": "biome format --write .",
    "type-check": "tsc",
    "spell-check": "cspell '**'",
    "test": "vitest",
    "test:report": "vitest run --coverage",
    "postinstall": "husky install"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "1.21.0",
    "@biomejs/biome": "1.9.4",
    "@vitest/coverage-v8": "3.0.5",
    "cspell": "8.15.4",
    "globals": "15.11.0",
    "husky": "9.1.6",
    "lint-staged": "15.2.10",
    "npm-check-updates": "17.1.8",
    "typescript": "5.6.3",
    "vitest": "3.0.5"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx}": ["bash -c 'cd frontend && tsc --noEmit'", "npx biome lint"],
    "frontend/**/*.{ts,tsx,js,json}": "npx biome format --write .",
    "*": "cspell '**'"
  },
  "volta": {
    "node": "22.16.0"
  }
}
