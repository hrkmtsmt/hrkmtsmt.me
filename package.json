{
  "name": "hrkmtsmt.me",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "lint": "biome lint",
    "format": "biome format --write .",
    "type-check": "tsc",
    "spell-check": "cspell '**'",
    "test": "vitest",
    "test:report": "vitest run --coverage",
    "postinstall": "husky install"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "1.21.0",
    "@biomejs/biome": "1.9.4",
    "@cloudflare/workers-types": "4.20241022.0",
    "@vitest/coverage-v8": "3.0.5",
    "cspell": "8.15.4",
    "globals": "15.11.0",
    "husky": "9.1.6",
    "lint-staged": "15.2.10",
    "npm-check-updates": "17.1.8",
    "typescript": "5.6.3",
    "vitest": "3.0.5",
    "wrangler": "3.83.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "bash -c tsc --noEmit",
      "pnpm run lint"
    ],
    "src/**/*.{ts,tsx,js,json}": "pnpm run format",
    "*": "pnpm run spell-check"
  },
  "volta": {
    "node": "22.16.0"
  }
}
