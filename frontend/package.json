		"dompurify": "^3.3.1",
		"isbot": "^5.1.35",
		"jotai": "^2.18.1",
		"marked": "^17.0.3",
		"marked-highlight": "^2.2.3",
		"marked-shiki": "^1.2.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router": "^7.13.0",
		"shiki": "^4.0.2",
